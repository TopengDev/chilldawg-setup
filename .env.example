# ──────────────────────────────────────────────────────────────────────────────
# chilldawg-setup — example environment file
#
# Copy to ~/.claude/secrets.env and fill in real values, then chmod 600.
#   cp .env.example ~/.claude/secrets.env
#   chmod 600 ~/.claude/secrets.env
#   $EDITOR ~/.claude/secrets.env
#
# ~/.bashrc sources ~/.claude/secrets.env on every interactive shell, so the
# variables below are available in any new terminal once filled in.
# ──────────────────────────────────────────────────────────────────────────────

# Anthropic API key — used by Claude API calls (Beacon, scripts, MCPs)
export ANTHROPIC_API_KEY=""

# Cloudflare DNS automation for aenoxa.com (scope: Zone.DNS edit only)
export CLOUDFLARE_API_TOKEN=""
export CLOUDFLARE_ZONE_ID=""

# VPS hosting deployed products — read-only by default unless explicitly authorized
export VPS_HOST=""
export VPS_USER=""
export VPS_PASSWORD=""

# GitHub Personal Access Token — for gh CLI + git operations over HTTPS
export GH_TOKEN=""

# Google AI Studio key — used by the nanobanana MCP (image generation/editing)
export NANOBANANA_API_KEY=""

# ISI / BMS WebAdmin + fitest portal logins — used by QA/fitest skills & flows
export ISI_EMAIL=""
export ISI_PASSWORD=""
export FITEST_USER=""
export FITEST_PASSWORD=""

# ──────────────────────────────────────────────────────────────────────────────
# chilldawg-setup .gitignore
# This repo is the source-of-truth for Christopher's Claude Code + dev env.
# Anything below MUST NOT be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Secrets (live) ──────────────────────────────────────────────────────────
secrets.env
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
.git-credentials
.gh.json
.netrc

# ─── Secrets (encrypted-at-rest + keys) ──────────────────────────────────────
# The age master key (lose it = lose every secret) + the encrypted secrets blob
# + any age/encrypted artifact. These are machine-local and MUST NEVER be
# committed, even though ~/.claude and ~/.config/age are not symlinked into this
# repo today (defensive — in case the key/blob ever lands under a tracked path).
secrets.env.enc
config/age/
keys.txt
*.age
*.enc

# ─── Claude Code runtime state (regeneratable, large, or sensitive) ──────────
claude/.credentials.json
claude/.mcp.json
claude/mcp-needs-auth-cache.json
claude/projects/
claude/sessions/
claude/cache/
claude/file-history/
claude/debug/
claude/backups/
claude/paste-cache/
claude/session-env/
claude/shell-snapshots/
claude/stats-cache.json
claude/statsig/
claude/telemetry/
claude/usage-data/
claude/todos/
claude/teams/
claude/channels/
claude/history.jsonl
claude/plans/
claude/invoices/
claude/plugins/
claude/settings.local.json

# ─── Live memory (private, machine-local, NOT committed) ─────────────────────
# claude/memory/ holds the running system's long-term memory .md files. It is a
# REAL on-disk directory that ~/.claude/memory symlinks into (settings.json
# autoMemoryDirectory). The files mutate constantly and contain private context
# (people, projects, credentials-by-reference), so memory is untracked here.
# The files stay on disk; git just doesn't version them.
claude/memory/

# ─── Shell history / runtime ─────────────────────────────────────────────────
.bash_history
.python_history
.node_repl_history
.lesshst
.viminfo
.claude.json
.claude.json.backup

# ─── Node / build artifacts ──────────────────────────────────────────────────
node_modules/
dist/
build/
*.log
*.lock
*.pid
*.swp
*.swo
.DS_Store
Thumbs.db

# Allow lockfiles for reproducibility (override the *.lock above)
!package-lock.json
!bun.lock
!bun.lockb
!Cargo.lock
!lazy-lock.json

# ─── Editor / OS ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.ipynb_checkpoints/

# ─── Qutebrowser personal state (we only track config.py + scripts/ + greasemonkey/) ──
config/qutebrowser/bookmarks/
config/qutebrowser/quickmarks
config/qutebrowser/qsettings/
config/qutebrowser/autoconfig.yml
config/qutebrowser/history.sqlite*
config/qutebrowser/sessions/
config/qutebrowser/webengine/

# ─── Sibling-cloned configs (not owned by chilldawg-setup) ───────────────────
# nvim has its own upstream repo (TopengDev/nvim_setup); install.sh clones it
# as a sibling into ~/.config/nvim. We never track it here.
config/nvim/

# ─── Defensive: nested git repos under config/ should never be tracked ───────
config/*/.git/
config/*/.gitignore

# ─── journal-audit runtime (operational state, not source) ───────────────────
# journal.md (the log) IS tracked; its derived audit state + backups are not.
claude/memory/.journal-audit-state.json
claude/memory-backups/
claude/scripts/__pycache__/
__pycache__/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.bak-*
*.draft
*.orig
*~

{
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "EDITOR": "nvim"
  },
  "permissions": {
    "allow": [
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Edit(~/.claude/memory/**)",
      "Write(~/.claude/memory/**)",
      "Edit(~/.claude/hooks/**)",
      "Write(~/.claude/hooks/**)",
      "Edit(/home/christopher/claude/Git/repositories/chilldawg-setup/**)",
      "Write(/home/christopher/claude/Git/repositories/chilldawg-setup/**)",
      "Edit(~/.claude/scripts/**)",
      "Write(~/.claude/scripts/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/christopher/.claude/hooks/oneshot-webapp-rules-hook.sh",
            "timeout": 10,
            "statusMessage": "Injecting /oneshot-webapp non-negotiables..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/christopher/.claude/scripts/memory-inject-hook.sh",
            "timeout": 8,
            "statusMessage": "Retrieving relevant memories..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"MEMORY REVIEW: about to compact — save unsaved decisions/corrections/projects/refs/feedback to memory before context is lost (/remember review).\"}'",
            "timeout": 5,
            "statusMessage": "Checking for unsaved memories..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/christopher/.claude/hooks/lint-check.sh",
            "timeout": 60,
            "statusMessage": "Running linter..."
          },
          {
            "type": "command",
            "command": "/home/christopher/.claude/scripts/memory-write-validate.sh",
            "timeout": 15,
            "statusMessage": "Validating memory write..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_playwright_playwright__browser_.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Playwright+Chrome is hard-banned in this environment. Use /agent-browser with qutebrowser instead. See ~/.claude/skills/agent-browser/SKILL.md and memory feedback_browser_qutebrowser.md. Proxy: curl http://localhost:9222/target, driver: agent-browser CLI (export AGENT_BROWSER_CDP=9222).\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/christopher/.claude/hooks/triage-gate-hook.sh",
            "timeout": 10,
            "statusMessage": "Triage gate check..."
          },
          {
            "type": "command",
            "command": "/home/christopher/.claude/hooks/block-raw-git-commit.sh",
            "timeout": 10,
            "statusMessage": "Checking for raw git commit..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "playwright@claude-plugins-official": true,
    "attn@s0nderlabs": true,
    "whatsapp@TopengDev": true,
    "nativ@nativ": true
  },
  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "s0nderlabs": {
      "source": {
        "source": "github",
        "repo": "s0nderlabs/marketplace"
      },
      "autoUpdate": true
    },
    "TopengDev": {
      "source": {
        "source": "github",
        "repo": "TopengDev/whatsapp-marketplace"
      }
    },
    "nativ": {
      "source": {
        "source": "github",
        "repo": "s0nderlabs/nativ"
      }
    }
  },
  "effortLevel": "xhigh",
  "channelsEnabled": true,
  "allowedChannelPlugins": [
    {
      "marketplace": "s0nderlabs",
      "plugin": "attn"
    },
    {
      "marketplace": "TopengDev",
      "plugin": "whatsapp"
    }
  ],
  "autoMemoryDirectory": "~/.claude/memory",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "agentPushNotifEnabled": false,
  "voiceEnabled": false
}
